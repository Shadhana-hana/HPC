#include <stdio.h>
#include <stdlib.h>
#include <mpi.h>

#define SIZE 12

int main(int argc, char *argv[])
{
    int rank, size;
    int arr[SIZE];
    int sub_arr[SIZE];
    int number;
    int local_count = 0, total_count = 0;
    double start_time, end_time; // Variables for timing

    MPI_Init(&argc, &argv);
    MPI_Comm_rank(MPI_COMM_WORLD, &rank);
    MPI_Comm_size(MPI_COMM_WORLD, &size);

    int part = SIZE / size;

    if (rank == 0)
    {
        printf("[Master] Generating array of size %d...\n", SIZE);
        for (int i = 0; i < SIZE; i++) {
            arr[i] = rand() % 10;
            printf("%d ", arr[i]);
        }
        printf("\n\n[Master] Enter number to search: ");
        fflush(stdout);
        scanf("%d", &number);
        printf("------------------------------------------\n");
    }

    // Synchronize processes before starting the timer
    MPI_Barrier(MPI_COMM_WORLD);
    start_time = MPI_Wtime();

    // Distribute data
    MPI_Bcast(&number, 1, MPI_INT, 0, MPI_COMM_WORLD);
    MPI_Scatter(arr, part, MPI_INT, sub_arr, part, MPI_INT, 0, MPI_COMM_WORLD);

    // Local Search
    for (int i = 0; i < part; i++) {
        if (sub_arr[i] == number)
            local_count++;
    }

    // Collect results
    MPI_Reduce(&local_count, &total_count, 1, MPI_INT, MPI_SUM, 0, MPI_COMM_WORLD);

    end_time = MPI_Wtime(); // End timer

    // Each process reports its own execution time
    printf("Process %d: Local Count: %d | Execution Time: %f seconds\n",
            rank, local_count, (end_time - start_time));

    if (rank == 0)
    {
        printf("------------------------------------------\n");
        printf("[Result] Total Frequency: %d\n", total_count);
    }

    MPI_Finalize();
    return 0;
}
