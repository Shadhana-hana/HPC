#include <stdio.h>
#include <stdlib.h>
#include <omp.h>
#include <math.h>
#define N 1000
int main()
{
   int *A,*B,*C,i;
   int n;
   A = (int*)malloc(N*sizeof(int));
   printf("Enter the constant to be added:\n");
   scanf("%d",&n);
   for(i=0;i<N;i++)
   {
      A[i]=rand()%15;
   }
   printf("Random array:\n");
   for(i=0;i<5;i++)
   {
       printf("%d\n",A[i]);
   }

   double start = omp_get_wtime();
   #pragma omp parallel for
   for(i=0;i<N;i++)
   {
      A[i] = A[i] + n;
   }
   double end = omp_get_wtime();
   printf("\nTime Taken : %f seconds \n",end-start);
   printf("Resultant Array:\n");
   for(i=0;i<5;i++)
   {
      printf("%d\n",A[i]);
   }
   free(A);
   return 0;
}
